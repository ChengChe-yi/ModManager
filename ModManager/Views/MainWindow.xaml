<windowex:WindowEx
    x:Class="ModManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:windowex="using:WinUIEx"
    MinWidth="1360"
    MinHeight="768"
    PersistenceId="MainWindow"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid
            x:Name="GlobalBackgroundHost"
            IsHitTestVisible="False"
            RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="BackgroundScale" ScaleX="1.0" ScaleY="1.0" />
            </Grid.RenderTransform>
            <Image
                x:Name="GlobalBackgroundImage"
                Opacity="1"
                Stretch="UniformToFill" />
            <MediaPlayerElement
                x:Name="GlobalBackgroundVideo"
                AreTransportControlsEnabled="False"
                AutoPlay="True"
                Opacity="1"
                Stretch="UniformToFill"
                Visibility="Collapsed" />
        </Grid>
        <Grid
            x:Name="PageBackgroundOverlay"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False"
            Opacity="0" />


        <!--  主导航视图  -->
        <NavigationView
            x:Name="NavigationView"
            Margin="0,52,0,0"
            Background="Transparent"
            CompactPaneLength="70"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            Loaded="NavigationView_Loaded"
            OpenPaneLength="150"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="NavigationView_SelectionChanged">

            <NavigationView.Resources>
                <ResourceDictionary>

                    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent" />

                    <FontFamily x:Key="ActionIconFont">Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>

                    <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>
                    <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
                    <CornerRadius x:Key="NavigationViewItemCornerRadius">0</CornerRadius>
                    <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                    <Thickness x:Key="NavigationViewBorderThickness">0</Thickness>

                    <Style TargetType="NavigationViewItem">
                        <Setter Property="MinHeight" Value="48" />
                        <Setter Property="FocusVisualMargin" Value="0" />
                        <Setter Property="FocusVisualPrimaryBrush" Value="Transparent" />
                        <Setter Property="FocusVisualSecondaryBrush" Value="Transparent" />
                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                        <Setter Property="Margin" Value="0,1,0,1" />
                    </Style>
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                </ResourceDictionary>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <TextBlock
                    Margin="12,68,0,8"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="" />
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="主页" Tag="ModManager.ViewModels.MainViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            FontFamily="{StaticResource ActionIconFont}"
                            FontSize="36"
                            Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="MOD管理" Tag="ModManager.ViewModels.ModManagerViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            FontFamily="{StaticResource ActionIconFont}"
                            FontSize="36"
                            Glyph="&#xEA86;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="角色列表" Tag="ModManager.ViewModels.CharacterViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            FontFamily="{StaticResource ActionIconFont}"
                            FontSize="36"
                            Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="下载" Tag="downloads">
                    <NavigationViewItem.Icon>
                        <FontIcon FontSize="36" FontFamily="{StaticResource ActionIconFont}" Glyph="&#xE774;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="设置中心" Tag="ModManager.ViewModels.SettingsViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            x:Name="SettingsIcon"
                            FontFamily="{StaticResource ActionIconFont}"
                            FontSize="36"
                            Glyph="&#xE713;"
                            RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform x:Name="SettingsIconRotation" Angle="0" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Background="Transparent">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition>
                            <EntranceNavigationTransitionInfo IsTargetElement="False"/>
                        </NavigationThemeTransition>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>

        <!--  通知中心（右下角，最高 Z 序）  -->
        <Grid
            x:Name="NotificationHost"
            Width="380"
            MaxHeight="450"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,60"
            Visibility="Collapsed"
            Canvas.ZIndex="9999">

            <Border x:Name="ContainerBorder"
                    CornerRadius="10" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--  标题栏  -->
                <Grid Grid.Row="0" Padding="16,12,16,8">
                    <TextBlock Text="通知中心"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <Button x:Name="ClearAllButton"
                            Content="全部清除"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            Padding="8,4"/>
                </Grid>

                <!--  通知卡片列表  -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,0,12,12">
                    <StackPanel x:Name="NotificationPanel"
                                Orientation="Vertical"
                                Spacing="8"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!--  自定义标题栏区域  -->
        <Grid
            x:Name="AppTitleBar"
            Height="50"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Canvas.ZIndex="1000"
            IsHitTestVisible="False">

            <Border
                Padding="8,4,12,4"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="Transparent"
                CornerRadius="8">

                <StackPanel Orientation="Horizontal" Spacing="0">
                    <Image
                        x:Name="TitleBarIcon"
                        Width="50"
                        Height="50"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center" />
                    <TextBlock
                        x:Name="TitleBarText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Mod管理器" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</windowex:WindowEx>