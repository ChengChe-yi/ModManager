<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ModManager.Views.ModManagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:community="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:ModManager.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ModManager.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
        <converters:ModCountFormatterConverter x:Key="ModCountFormatterConverter" />
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <converters:CollectionCountToVisibilityConverter x:Key="CollectionCountToVisibilityConverter" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="GlassListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid x:Name="ContentGrid">
                                <Grid.RenderTransform>
                                    <CompositeTransform
                                        x:Name="ItemTransform"
                                        ScaleX="1.0"
                                        ScaleY="1.0"
                                        TranslateY="0" />
                                </Grid.RenderTransform>
                                <ContentPresenter
                                    x:Name="ContentPresenter"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}" />
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.02"
                                                Duration="0:0:0.15" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.02"
                                                Duration="0:0:0.15" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#30FFFFFF"
                                                Duration="0:0:0.15" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="0.96"
                                                Duration="0:0:0.05" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0.96"
                                                Duration="0:0:0.05" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="TranslateY"
                                                To="2"
                                                Duration="0:0:0.05" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#10FFFFFF"
                                                Duration="0:0:0.05" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#25FFFFFF"
                                                Duration="0" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOverSelected">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.02"
                                                Duration="0:0:0.15" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.02"
                                                Duration="0:0:0.15" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#35FFFFFF"
                                                Duration="0:0:0.15" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="#A0FFFFFF"
                                                Duration="0:0:0.15" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="0.96"
                                                Duration="0:0:0.05" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0.96"
                                                Duration="0:0:0.05" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ItemTransform"
                                                Storyboard.TargetProperty="TranslateY"
                                                To="2"
                                                Duration="0:0:0.05" />
                                            <ColorAnimation
                                                Storyboard.TargetName="RootBorder"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#18FFFFFF"
                                                Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition Width="0.4*" />
        </Grid.ColumnDefinitions>
        <Grid
            Grid.Row="2"
            Grid.Column="0"
            Margin="16,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Height="32"
                    Margin="0,0,0,4"
                    Opacity="0"
                    Orientation="Horizontal">

                    <Button Width="32" Height="32" />
                </StackPanel>
                <Border
                    Grid.Row="1"
                    Padding="0"
                    Style="{StaticResource GlassCardStyle}">
                    <ScrollViewer
                        x:Name="PrimaryScrollViewer"
                        Margin="0,0,-6,0"
                        Padding="0,0,6,0"
                        VerticalScrollBarVisibility="Auto">
                        <ListView
                            x:Name="ListView_CategoryPrimary"
                            DoubleTapped="ListView_CategoryPrimary_DoubleTapped"
                            ItemContainerStyle="{StaticResource GlassListViewItemStyle}"
                            RightTapped="ListView_CategoryPrimary_RightTapped"
                            SelectionChanged="ListView_CategoryPrimary_SelectionChanged"
                            Style="{StaticResource GlassListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ModCategory">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Width="4"
                                            Height="40"
                                            Margin="0,4,8,4"
                                            CornerRadius="2"
                                            Visibility="{x:Bind NotEnable}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Offset="0" Color="#FF5555" />
                                                    <GradientStop Offset="1" Color="#CC3333" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Grid Grid.Column="1" Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Image
                                                Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                Margin="0,0,12,0"
                                                Source="{x:Bind BackgroundImage}"
                                                Stretch="Uniform" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    HorizontalAlignment="Left"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Style="{ThemeResource BaseTextBlockStyle}"
                                                    Text="{x:Bind DisplayName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind ModNumber, Converter={StaticResource ModCountFormatterConverter}, ConverterParameter='个对象'}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>
            </Grid>
            <Grid Grid.Column="1" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button
                        x:Name="BtnSecondaryEnabledFirst"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterSecondaryEnabledFirst_Click"
                        ToolTipService.ToolTip="先启用后禁用（排序）">
                        <SymbolIcon Symbol="Sort" />
                    </Button>
                    <Button
                        x:Name="BtnSecondaryEnabled"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterSecondaryEnabled_Click"
                        ToolTipService.ToolTip="仅显示已启用">
                        <SymbolIcon Symbol="Accept" />
                    </Button>
                    <Button
                        x:Name="BtnSecondaryDisabled"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterSecondaryDisabled_Click"
                        ToolTipService.ToolTip="仅显示已禁用">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </StackPanel>
                <Border
                    Grid.Row="1"
                    Padding="0"
                    Style="{StaticResource GlassCardStyle}">
                    <ScrollViewer
                        x:Name="SecondaryScrollViewer"
                        Margin="0,0,-6,0"
                        Padding="0,0,6,0"
                        VerticalScrollBarVisibility="Auto">
                        <ListView
                            x:Name="ListView_CategorySecondary"
                            DoubleTapped="ListView_CategorySecondary_DoubleTapped"
                            ItemContainerStyle="{StaticResource GlassListViewItemStyle}"
                            RightTapped="ListView_CategorySecondary_RightTapped"
                            SelectionChanged="ListView_CategorySecondary_SelectionChanged"
                            Style="{StaticResource GlassListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ModCategory">
                                    <Grid
                                        Background="Transparent"
                                        PointerEntered="CategorySecondary_PointerEntered"
                                        PointerExited="CategorySecondary_PointerExited"
                                        PointerMoved="CategorySecondary_PointerMoved">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Canvas
                                            x:Name="HoverGlowCanvas"
                                            Width="0"
                                            Height="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            IsHitTestVisible="False">
                                            <Ellipse
                                                x:Name="HoverGlow"
                                                Width="120"
                                                Height="120"
                                                IsHitTestVisible="False"
                                                Opacity="0">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Offset="0" Color="#40FFFFFF" />
                                                        <GradientStop Offset="1" Color="Transparent" />
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                                <Ellipse.RenderTransform>
                                                    <TranslateTransform X="-60" Y="-60" />
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                        </Canvas>
                                        <Border
                                            Grid.Column="0"
                                            Width="4"
                                            Height="40"
                                            Margin="0,4,8,4"
                                            CornerRadius="2"
                                            IsHitTestVisible="False"
                                            Visibility="{x:Bind NotEnable}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Offset="0" Color="#FF5555" />
                                                    <GradientStop Offset="1" Color="#CC3333" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Grid
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            IsHitTestVisible="False">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Image
                                                Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                Margin="0,0,12,0"
                                                IsHitTestVisible="False"
                                                Source="{x:Bind BackgroundImage}"
                                                Stretch="Uniform" />
                                            <StackPanel
                                                Grid.Column="1"
                                                IsHitTestVisible="False"
                                                Spacing="2">
                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    HorizontalAlignment="Left"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    IsHitTestVisible="False"
                                                    Style="{ThemeResource BaseTextBlockStyle}"
                                                    Text="{x:Bind DisplayName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    IsHitTestVisible="False"
                                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind ModNumber, Converter={StaticResource ModCountFormatterConverter}, ConverterParameter='个Mod'}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <Button
                        x:Name="BtnModEnabledFirst"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterModEnabledFirst_Click"
                        ToolTipService.ToolTip="先启用后禁用（排序）">
                        <SymbolIcon Symbol="Sort" />
                    </Button>
                    <Button
                        x:Name="BtnModEnabled"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterModEnabled_Click"
                        ToolTipService.ToolTip="仅显示已启用">
                        <SymbolIcon Symbol="Accept" />
                    </Button>
                    <Button
                        x:Name="BtnModDisabled"
                        Width="32"
                        Height="32"
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="FilterModDisabled_Click"
                        ToolTipService.ToolTip="仅显示已禁用">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}">
                    <ScrollViewer
                        x:Name="ModScrollViewer"
                        Margin="0,0,-18,0"
                        Padding="0,0,18,0"
                        VerticalScrollBarVisibility="Auto">
                        <ListView
                            x:Name="ListView_ModItem"
                            AllowDrop="True"
                            DoubleTapped="ListView_ModItem_DoubleTapped"
                            DragOver="ListView_ModItem_DragOver"
                            Drop="ListView_ModItem_Drop"
                            ItemContainerStyle="{StaticResource GlassListViewItemStyle}"
                            RightTapped="ListView_ModItem_RightTapped"
                            SelectionChanged="ListView_ModItem_SelectionChanged"
                            Style="{StaticResource GlassListViewStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ModItem">
                                    <Grid
                                        Background="Transparent"
                                        PointerEntered="ModItem_PointerEntered"
                                        PointerExited="ModItem_PointerExited"
                                        PointerMoved="ModItem_PointerMoved">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Canvas
                                            x:Name="HoverGlowCanvas"
                                            Width="0"
                                            Height="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            IsHitTestVisible="False">
                                            <Ellipse
                                                x:Name="HoverGlow"
                                                Width="120"
                                                Height="120"
                                                IsHitTestVisible="False"
                                                Opacity="0">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Offset="0" Color="#40FFFFFF" />
                                                        <GradientStop Offset="1" Color="Transparent" />
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                                <Ellipse.RenderTransform>
                                                    <TranslateTransform X="-60" Y="-60" />
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                        </Canvas>
                                        <Border
                                            Grid.Column="0"
                                            Width="4"
                                            Height="40"
                                            Margin="0,4,8,4"
                                            CornerRadius="2">
                                            <Border.Background>
                                                <Binding Converter="{StaticResource StatusToBrushConverter}" Path="Enable" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                HorizontalAlignment="Left"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Style="{ThemeResource BaseTextBlockStyle}"
                                                Text="{x:Bind DisplayName}" />
                                            <TextBlock
                                                HorizontalAlignment="Left"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Text="{x:Bind Enable, Converter={StaticResource BoolToStatusConverter}}" />
                                        </StackPanel>

                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Border>
                <Border
                    Grid.Row="2"
                    Margin="0,4,0,0"
                    Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4"
                    Visibility="Collapsed">
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="将文件夹拖放到此处以添加 Mod" />
                </Border>
            </Grid>
        </Grid>
        <Grid
            Grid.Row="2"
            Grid.Column="1"
            Margin="8,8,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,8"
                Padding="12"
                CornerRadius="8">
                <Border.Background>
                    <AcrylicBrush
                        FallbackColor="#60FFFFFF"
                        TintColor="#80FFFFFF"
                        TintOpacity="0.3" />
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid
                        x:Name="ImageViewerGrid"
                        Grid.Row="0"
                        Visibility="Collapsed">
                        <Border
                            Margin="4"
                            Padding="4"
                            Background="Transparent"
                            CornerRadius="6">
                            <Image
                                x:Name="ModPreviewImage"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Stretch="Uniform" />
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Click="Button_PasteClipboardImage_Click" Text="粘贴或替换为剪切板中的图片" />
                                    <MenuFlyoutItem
                                        x:Name="MenuFlyoutItem_DeleteThisModPreviewPicture"
                                        Click="MenuFlyoutItem_DeleteThisModPreviewPicture_Click"
                                        Text="删除这张预览图" />
                                </MenuFlyout>
                            </Border.ContextFlyout>
                        </Border>
                    </Grid>
                    <Button
                        x:Name="AddImageButton"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Button_PasteClipboardImage_Click"
                        Style="{StaticResource ModernButtonStyle}"
                        Visibility="Visible">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Paste" />
                            <TextBlock Text="粘贴剪贴板图片" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
            <Border
                x:Name="ModKeyListBorder"
                Grid.Row="1"
                Style="{StaticResource GlassCardStyle}"
                Visibility="{Binding ElementName=DataGrid_ModKeyList, Path=ItemsSource, Converter={StaticResource CollectionCountToVisibilityConverter}}">
                <Expander
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    IsExpanded="True">
                    <Expander.Header>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource BaseTextBlockStyle}"
                                   Text="Mod按键列表" />
                    </Expander.Header>
                    <community:DataGrid
                        x:Name="DataGrid_ModKeyList"
                        MinHeight="100"
                        MaxHeight="500"
                        HorizontalAlignment="Stretch"
                        AutoGenerateColumns="False"
                        BorderThickness="0"
                        CanUserReorderColumns="False"
                        CanUserSortColumns="True"
                        IsReadOnly="True"
                        IsTabStop="False"
                        SelectionMode="Single">
                        <community:DataGrid.Resources>
                            <Color x:Key="DataGridRowSelectedBackgroundColor">Transparent</Color>
                            <Color x:Key="DataGridRowSelectedUnfocusedBackgroundColor">Transparent</Color>
                            <Color x:Key="DataGridRowSelectedHoveredBackgroundColor">Transparent</Color>
                            <Color x:Key="DataGridRowSelectedHoveredUnfocusedBackgroundColor">Transparent</Color>
                            <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent" />
                        </community:DataGrid.Resources>
                        <community:DataGrid.Columns>
                            <community:DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding KeyName}"
                                Header="按键名称"
                                IsReadOnly="True" />
                            <community:DataGridTextColumn
                                Width="Auto"
                                MinWidth="80"
                                Binding="{Binding VariableName}"
                                Header="变量名"
                                IsReadOnly="True" />
                            <community:DataGridTextColumn
                                Width="Auto"
                                MinWidth="80"
                                Binding="{Binding InitialValue}"
                                Header="初始值"
                                IsReadOnly="True" />
                            <community:DataGridTextColumn
                                Width="Auto"
                                MinWidth="100"
                                Binding="{Binding KeyValue}"
                                Header="值"
                                IsReadOnly="True" />
                            <community:DataGridTextColumn
                                Width="Auto"
                                MinWidth="100"
                                Binding="{Binding KeyType}"
                                Header="按键类型"
                                IsReadOnly="True" />
                        </community:DataGrid.Columns>
                    </community:DataGrid>
                </Expander>
            </Border>
        </Grid>

        <!-- 加载/空状态覆盖层 -->
        <Grid x:Name="ModLoadingOverlay" Visibility="Collapsed" Canvas.ZIndex="100"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.7">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <ProgressRing IsActive="True" Width="36" Height="36" />
                <TextBlock Text="加载中..." FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
        <Grid x:Name="ModEmptyHint" Visibility="Collapsed" Canvas.ZIndex="100"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="暂无 Mod 分类" FontSize="14" TextAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Page>