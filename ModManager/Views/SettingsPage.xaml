<Page
    x:Class="ModManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <Page.Resources>

        <Storyboard x:Name="EntranceStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="RootLayoutGrid"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="ExitStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="RootLayoutGrid"
                Storyboard.TargetProperty="Opacity"
                From="1"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SettingItemStyle" TargetType="StackPanel">
            <Setter Property="Spacing" Value="8" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>

        <!--  导航菜单项样式  -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="MinHeight" Value="48" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootLayoutGrid" Opacity="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左侧导航  -->
        <ScrollViewer
            Grid.Column="0"
            Width="220"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <NavigationView
                x:Name="SettingsNavigationView"
                IsBackButtonVisible="Collapsed"
                IsPaneOpen="True"
                IsPaneToggleButtonVisible="False"
                IsSettingsVisible="False"
                PaneDisplayMode="Left"
                SelectionChanged="SettingsNavigationView_SelectionChanged">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="外观与个性化" Tag="AppearanceItem">
                        <NavigationViewItem.Icon>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="背景与视觉效果" Tag="BackgroundItem">
                        <NavigationViewItem.Icon>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FD;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="窗口行为" Tag="WindowBehaviorItem">
                        <NavigationViewItem.Icon>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B3;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem Content="关于" Tag="AboutItem">
                        <NavigationViewItem.Icon>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE897;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>
            </NavigationView>
        </ScrollViewer>

        <!--  右侧内容区  -->
        <ScrollViewer
            x:Name="SettingsScrollViewer"
            Grid.Column="1"
            Padding="32,32,12,24"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!--  外观与个性化卡片  -->
                <Border x:Name="AppearanceItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="外观与个性化" />

                        <TextBlock
                            FontSize="14"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="应用主题" />
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <RadioButton
                                x:Name="ThemeLightRadio"
                                Click="ThemeRadio_Click"
                                Content="浅色模式"
                                FontSize="14"
                                GroupName="AppTheme"
                                Tag="0" />
                            <RadioButton
                                x:Name="ThemeDarkRadio"
                                Click="ThemeRadio_Click"
                                Content="深色模式"
                                FontSize="14"
                                GroupName="AppTheme"
                                Tag="1" />
                            <RadioButton
                                x:Name="ThemeDefaultRadio"
                                Click="ThemeRadio_Click"
                                Content="跟随系统设置"
                                FontSize="14"
                                GroupName="AppTheme"
                                Tag="2" />
                        </StackPanel>

                        <!--  三个透明度调节  -->
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBlock
                                FontSize="14"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="背景图片透明度" />
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="12">
                                <Slider
                                    x:Name="BgImageOpacitySlider"
                                    Width="260"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.05"
                                    ValueChanged="BgImageOpacitySlider_ValueChanged" />
                                <TextBlock x:Name="BgImageOpacityValue" MinWidth="40" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!--  背景与视觉效果卡片  -->
                <Border x:Name="BackgroundItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="背景与视觉效果" />

                        <ToggleSwitch
                            x:Name="BackgroundEnabledToggle"
                            Header="启用自定义背景"
                            OffContent="已禁用"
                            OnContent="已启用"
                            Toggled="BackgroundEnabledToggle_Toggled" />

                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBlock
                                FontSize="14"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="背景服务器" />
                            <ComboBox
                                x:Name="ServerComboBox"
                                Width="200"
                                SelectionChanged="ServerComboBox_SelectionChanged">
                                <ComboBoxItem Content="国服" Tag="0" />
                                <ComboBoxItem Content="国际服" Tag="1" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBlock
                                FontSize="14"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="自定义背景路径" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="CustomPathTextBox"
                                    Grid.Column="0"
                                    PlaceholderText="留空则使用在线背景"
                                    TextChanged="CustomPathTextBox_TextChanged" />
                                <Button
                                    x:Name="BrowseBackgroundButton"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Click="BrowseBackgroundButton_Click"
                                    Content="浏览" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <ToggleSwitch
                                x:Name="AcrylicOverlayToggle"
                                Header="启用页面亚克力模糊遮罩"
                                OffContent="纯色"
                                OnContent="亚克力模糊"
                                Toggled="AcrylicOverlayToggle_Toggled" />
                            <TextBlock
                                Margin="0,2,0,8"
                                Opacity="0.7"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="注意：当使用视频背景时，为保证性能，将自动回退为纯色背景" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  窗口行为卡片（含 Mod 路径）  -->
                <Border x:Name="WindowBehaviorItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,16"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="窗口行为" />

                        <ToggleSwitch
                            x:Name="MinimizeToTrayToggle"
                            Header="关闭后最小化至系统托盘"
                            OffContent="已禁用"
                            OnContent="已启用"
                            Toggled="MinimizeToTrayToggle_Toggled" />

                        <ToggleSwitch
                            x:Name="SaveWindowSizeToggle"
                            Margin="0,16,0,0"
                            Header="记住窗口大小"
                            OffContent="已禁用"
                            OnContent="已启用"
                            Toggled="SaveWindowSizeToggle_Toggled" />

                        <!--  下载线程数  -->
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBlock
                                FontSize="14"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="并行下载线程数" />
                            <TextBlock
                                Margin="0,2,0,8"
                                Opacity="0.7"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="更多线程可能加快下载速度，但也会增加内存占用。范围 1-32，默认 8。" />
                            <NumberBox
                                x:Name="DownloadThreadsNumberBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Minimum="1"
                                Maximum="32"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="DownloadThreadsNumberBox_ValueChanged" />
                        </StackPanel>

                        <!--  Mod 存储路径  -->
                        <StackPanel Style="{StaticResource SettingItemStyle}">
                            <TextBlock
                                FontSize="14"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="Mod 存储路径" />
                            <TextBlock
                                Margin="0,2,0,8"
                                Opacity="0.7"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Mods 文件夹的存放位置，修改后需要重启应用生效" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="ModsFolderPathTextBox"
                                    Grid.Column="0"
                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                    IsReadOnly="True"
                                    Text="" />
                                <Button
                                    x:Name="BrowseModsFolderButton"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Click="BrowseModsFolderButton_Click"
                                    Content="浏览" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
                                <Button x:Name="ResetModsFolderButton"
                                        Padding="12,6"
                                        Click="ResetModsFolderButton_Click"
                                        Content="重置为默认路径" />
                                <Button x:Name="DeployAssetsButton"
                                        Padding="12,6"
                                        Click="DeployAssets_Click"
                                        Content="部署角色数据" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  关于卡片  -->
                <Border x:Name="AboutItem" Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="关于" />
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="ModManager" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="版本 1.0.7" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="OnAboutClick"
                                    Content="关于" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>